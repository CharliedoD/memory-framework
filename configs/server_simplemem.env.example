# Copy this to .env at the repository root, or export the variables in your shell.
# The CLI loads repository-root .env automatically.
# Values mirror the server vLLM setup, but real judge keys remain local secrets.

HF_HOME=.cache/huggingface
TRANSFORMERS_CACHE=.cache/huggingface

EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_BACKEND=api
EMBEDDING_BASE_URL=http://127.0.0.1:8001/v1
EMBEDDING_API_KEY=EMPTY
EMBEDDING_MAX_INPUT_BYTES=8192

ANSWERER_BASE_URL=http://127.0.0.1:8000/v1
ANSWERER_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
ANSWERER_API_KEY=EMPTY
ANSWER_BASE_URL=http://127.0.0.1:8000/v1
ANSWER_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
ANSWER_API_KEY=EMPTY
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_API_KEY=EMPTY
LLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

JUDGE_BASE_URL=https://api.deepseek.com
JUDGE_MODEL=deepseek-v4-flash
JUDGE_API_KEY=replace_with_your_key
